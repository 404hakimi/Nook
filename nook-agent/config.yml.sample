# nook-agent 配置示例; 装机时由 backend 渲染 + SSH 写到 /home/nook-agent/config.yml.

backend:
  api_url: http://backend.example.com:8080
  api_token: <由 backend 装机时生成的 64 char hex>
  timeout_seconds: 120

heartbeat:
  interval_seconds: 60

nic:
  interval_seconds: 300
  interface: auto

# Xray 段仅 frontline role 出现; landing role 无此段
xray:
  bin: /usr/local/bin/xray
  api_port: 10085
  stats_interval_seconds: 300
