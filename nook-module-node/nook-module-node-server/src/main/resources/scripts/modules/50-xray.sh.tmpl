# Module 50 — xray binary + 共享 inbound (vmess+ws, users 空) + 仅 api/blackhole 两个静态 outbound.
# 业务出站 (tag=clientId 的 socks5) 全部靠 `xray api ado` 动态加; restart 兜底走 blackhole 防 IP 泄漏.

log "=== Module 50: Xray 安装 (版本: {{XRAY_VERSION}}, 安装到: {{INSTALL_DIR}}) ==="

INSTALL_DIR="{{INSTALL_DIR}}"
LOG_DIR="{{LOG_DIR}}"
XRAY_VERSION="{{XRAY_VERSION}}"
XRAY_API_PORT={{XRAY_API_PORT}}
LOG_LEVEL="{{LOG_LEVEL}}"
RESTART_POLICY="{{RESTART_POLICY}}"
ENABLE_ON_BOOT="{{ENABLE_ON_BOOT}}"
FORCE_REINSTALL="{{FORCE_REINSTALL}}"
SHARED_INBOUND_PORT={{SHARED_INBOUND_PORT}}
WS_PATH="{{WS_PATH}}"
USE_TLS="{{USE_TLS}}"
DOMAIN="{{DOMAIN}}"
TLS_CERT_PATH="{{TLS_CERT_PATH}}"
TLS_KEY_PATH="{{TLS_KEY_PATH}}"

# 路径全部由 Java 计算 + 经模板下发, 跟 xray_install 表 DB 字段一一对应 (单点真理).
# 脚本不再自己拼 "$INSTALL_DIR/bin/xray" 这种, 防止 Java 端跟脚本端布局漂移.
XRAY_BIN="{{XRAY_BINARY_PATH}}"
XRAY_CONFIG="{{XRAY_CONFIG_PATH}}"
XRAY_SHARE="{{XRAY_SHARE_DIR}}"
SYSTEMD_UNIT="{{XRAY_SYSTEMD_UNIT_PATH}}"

ARCH=$(uname -m)
case "$ARCH" in
    x86_64|amd64)   ZIP_NAME="Xray-linux-64.zip" ;;
    aarch64|arm64)  ZIP_NAME="Xray-linux-arm64-v8a.zip" ;;
    armv7l|armv7)   ZIP_NAME="Xray-linux-arm32-v7a.zip" ;;
    *) err "不支持的架构: $ARCH"; exit 1 ;;
esac
if [[ "$XRAY_VERSION" == "latest" || -z "$XRAY_VERSION" ]]; then
    DOWNLOAD_URL="https://github.com/XTLS/Xray-core/releases/latest/download/$ZIP_NAME"
else
    DOWNLOAD_URL="https://github.com/XTLS/Xray-core/releases/download/$XRAY_VERSION/$ZIP_NAME"
fi

NEED_INSTALL=1
if [[ "$FORCE_REINSTALL" == "true" ]]; then
    log "强制重装 (前端勾选)"
elif [[ -x "$XRAY_BIN" ]]; then
    INSTALLED_RAW=$("$XRAY_BIN" version 2>/dev/null | head -1 || echo "?")
    INSTALLED_VER=$(echo "$INSTALLED_RAW" | awk '{print $2}')
    if [[ "$XRAY_VERSION" != "latest" && -n "$XRAY_VERSION" && "$XRAY_VERSION" == "v$INSTALLED_VER" ]]; then
        warn "Xray 已是目标版本 v$INSTALLED_VER (跳过下载)"
        NEED_INSTALL=0
    else
        log "Xray 已装 v$INSTALLED_VER, 目标 $XRAY_VERSION → 重装"
    fi
fi

if [[ $NEED_INSTALL -eq 1 ]]; then
    if ! command -v wget >/dev/null 2>&1 || ! command -v unzip >/dev/null 2>&1; then
        log "安装下载依赖 wget / unzip..."
        export DEBIAN_FRONTEND=noninteractive
        wait_for_dpkg_lock
        apt-get update -qq
        apt-get install -y -qq wget unzip
    fi
fi

XRAY_BIN_DIR="$(dirname "$XRAY_BIN")"
XRAY_CONFIG_DIR="$(dirname "$XRAY_CONFIG")"

if [[ $NEED_INSTALL -eq 1 && -x "$XRAY_BIN" ]]; then
    OLD_VER=$("$XRAY_BIN" version 2>/dev/null | head -1 | awk '{print $2}' || echo "")
    if [[ -n "$OLD_VER" && "$OLD_VER" != "?" ]]; then
        BAK_BIN="$XRAY_BIN_DIR/xray.bak.v$OLD_VER"
        cp "$XRAY_BIN" "$BAK_BIN"
        log "✔ 已备份旧 binary v$OLD_VER → $BAK_BIN"
    fi
fi

# 先停 service: 即使不重装也要保证 daemon-reload + 新 config 生效
systemctl stop xray >/dev/null 2>&1 || true

mkdir -p "$XRAY_BIN_DIR" "$XRAY_CONFIG_DIR" "$XRAY_SHARE" "$LOG_DIR"
if [[ $NEED_INSTALL -eq 1 ]]; then
    log "下载 Xray ($XRAY_VERSION, $ARCH)..."
    log "  URL: $DOWNLOAD_URL"
    TMPZIP=$(mktemp /tmp/xray-XXXXXX.zip)
    if ! wget -q -O "$TMPZIP" "$DOWNLOAD_URL"; then
        rm -f "$TMPZIP"
        err "下载失败: $DOWNLOAD_URL"
        exit 1
    fi
    unzip -o -q "$TMPZIP" xray       -d "$XRAY_BIN_DIR/"
    # geo 文件个别架构 release 不含, 解不出不阻断主流程
    unzip -o -q "$TMPZIP" "geo*.dat" -d "$XRAY_SHARE/" 2>/dev/null || true
    rm -f "$TMPZIP"
    chmod +x "$XRAY_BIN"
    log "✔ Xray binary: $XRAY_BIN"
fi

# TLS 块: 45-acme-tls 已落好 cert/key, 这里只渲染 streamSettings.tlsSettings 片段
STREAM_TLS_BLOCK=""
if [[ "$USE_TLS" == "true" ]]; then
    if [[ ! -f "$TLS_CERT_PATH" || ! -f "$TLS_KEY_PATH" ]]; then
        err "USE_TLS=true 但 cert/key 文件不存在: $TLS_CERT_PATH — 检查 45-acme-tls 是否成功"
        exit 1
    fi
    # serverName = $DOMAIN, 让客户端 IP 直连时 SNI 不匹配握手失败
    STREAM_TLS_BLOCK="\"security\": \"tls\","$'\n'"        \"tlsSettings\": {"$'\n'"          \"serverName\": \"$DOMAIN\","$'\n'"          \"alpn\": [\"h2\", \"http/1.1\"],"$'\n'"          \"minVersion\": \"1.2\","$'\n'"          \"certificates\": [{ \"certificateFile\": \"$TLS_CERT_PATH\", \"keyFile\": \"$TLS_KEY_PATH\" }]"$'\n'"        },"
    log "✔ TLS 块已渲染 (复用 $TLS_CERT_PATH)"
else
    log "useTls=false, xray inbound 走纯 ws"
fi

if [[ -f "$XRAY_CONFIG" ]]; then
    BACKUP="${XRAY_CONFIG}.bak.$(date +%s)"
    cp "$XRAY_CONFIG" "$BACKUP"
    log "原 config 备份到 $BACKUP"
fi

gen_outbounds() {
    # 顺序很重要: blackhole 放第一位 = 默认兜底出站 (任何未匹配 routing rule 的流量进它就被丢);
    # api outbound 仅给 xray 自己的 api inbound 用 (走 routing rule 显式匹配, 不会落到默认).
    # 真实业务出站 (tag=clientId 的 socks5) 全程靠 `xray api ado` 动态加, 不在 config.json 里.
    echo '    { "tag": "blackhole", "protocol": "blackhole" },'
    echo '    { "tag": "api",       "protocol": "freedom" }'
}

cat > "$XRAY_CONFIG" <<XRAYCONF
{
  "log": {
    "access": "$LOG_DIR/access.log",
    "error":  "$LOG_DIR/error.log",
    "loglevel": "$LOG_LEVEL"
  },
  "api": {
    "tag": "api",
    "services": ["HandlerService", "LoggerService", "StatsService", "RoutingService"]
  },
  "stats": {},
  "policy": {
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    },
    "levels": {
      "0": { "statsUserUplink": true, "statsUserDownlink": true }
    }
  },
  "inbounds": [
    {
      "tag": "api",
      "listen": "127.0.0.1",
      "port": $XRAY_API_PORT,
      "protocol": "dokodemo-door",
      "settings": { "address": "127.0.0.1" }
    },
    {
      "tag": "in_shared",
      "listen": "0.0.0.0",
      "port": $SHARED_INBOUND_PORT,
      "protocol": "vmess",
      "settings": { "users": [] },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      },
      "streamSettings": {
        "network": "ws",
        $STREAM_TLS_BLOCK
        "wsSettings": { "path": "$WS_PATH" }
      }
    }
  ],
  "outbounds": [
$(gen_outbounds)
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      { "inboundTag": ["api"], "outboundTag": "api" }
    ]
  }
}
XRAYCONF

# Go 软内存上限: 1C1G 小机挂多用户跑大流量(speedtest)时, 防 xray 堆冲高被内核 OOM 杀掉.
# 按本机实际内存的 70% 自适应 (留 OS + nook-agent 余量); 堆接近上限时 Go 主动狠 GC 而非崩溃.
# 单核机不设 GOGC=20 (会跟代理抢 CPU), GOMEMLIMIT 自身已是"接近上限才频繁 GC"的自适应策略.
MEM_TOTAL_KB=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
GO_MEM_LIMIT_MIB=$(( MEM_TOTAL_KB * 70 / 100 / 1024 ))
[[ "$GO_MEM_LIMIT_MIB" -lt 128 ]] && GO_MEM_LIMIT_MIB=128
log "GOMEMLIMIT = ${GO_MEM_LIMIT_MIB}MiB (本机内存 $(( MEM_TOTAL_KB / 1024 ))MiB × 70%)"

# XRAY_LOCATION_ASSET 指向自定义 share 目录 (geo*.dat); 不在默认路径必须显式声明
cat > "$SYSTEMD_UNIT" <<UNITEOF
[Unit]
Description=Xray Service (nook deployed)
Documentation=https://github.com/XTLS/Xray-core
After=network.target nss-lookup.target

[Service]
User=root
ExecStart=$XRAY_BIN run -c $XRAY_CONFIG
Restart=$RESTART_POLICY
RestartSec=5
LimitNOFILE=65535
Environment=XRAY_LOCATION_ASSET=$XRAY_SHARE
Environment=GOMEMLIMIT=${GO_MEM_LIMIT_MIB}MiB

[Install]
WantedBy=multi-user.target
UNITEOF

log "校验 Xray config..."
if ! XRAY_LOCATION_ASSET="$XRAY_SHARE" "$XRAY_BIN" run -test -c "$XRAY_CONFIG" >/dev/null 2>&1; then
    err "Xray config 校验失败!"
    XRAY_LOCATION_ASSET="$XRAY_SHARE" "$XRAY_BIN" run -test -c "$XRAY_CONFIG" 2>&1 || true
    exit 1
fi

systemctl daemon-reload
if [[ "$ENABLE_ON_BOOT" == "true" ]]; then
    systemctl enable xray >/dev/null 2>&1 || true
    log "✔ 开机自启已启用"
else
    systemctl disable xray >/dev/null 2>&1 || true
    warn "开机自启未启用 (按前端勾选; 服务器重启后 Xray 不会自动起)"
fi
systemctl restart xray
sleep 2

if ! systemctl is-active --quiet xray; then
    err "Xray 启动失败!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi

sleep 1
if ss -ltn 2>/dev/null | grep -q "127.0.0.1:$XRAY_API_PORT "; then
    log "✔ Xray gRPC API: 127.0.0.1:$XRAY_API_PORT"
else
    err "Xray gRPC API 未监听!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi

OUTBOUND_COUNT=$(jq '.outbounds | length' "$XRAY_CONFIG")
RULE_COUNT=$(jq '.routing.rules | length' "$XRAY_CONFIG")
# `xray version | head -1` 下 set -o pipefail + xray 写多行被 head 截断 → SIGPIPE (141), 触发 set -e 退出.
# 加 2>/dev/null + || echo "?" 兜底, 跟脚本前面 INSTALLED_RAW 用同一套写法.
INSTALLED_VER=$("$XRAY_BIN" version 2>/dev/null | head -1 || echo "?")
log "✔ Module 50 完成: $INSTALLED_VER, $OUTBOUND_COUNT outbound, $RULE_COUNT routing rule"
log "  binary:  $XRAY_BIN"
log "  config:  $XRAY_CONFIG"
log "  share:   $XRAY_SHARE"
log "  logs:    $LOG_DIR"
log "  systemd: $SYSTEMD_UNIT"
