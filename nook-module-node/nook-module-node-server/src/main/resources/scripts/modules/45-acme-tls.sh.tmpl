# Module 45 — TLS 证书 (acme.sh + Cloudflare DNS-01).
# 出口契约: $TLS_CERT_PATH / $TLS_KEY_PATH 一定存在且对当前 $DOMAIN 有效.
# 复用策略: cert 剩余 > 7 天且匹配当前 DOMAIN 就跳过签发, 避开 Let's Encrypt 周 5 张配额.

log "=== Module 45: TLS 证书 (acme.sh + Cloudflare DNS-01) ==="

DOMAIN="{{DOMAIN}}"
CF_API_TOKEN="{{CF_API_TOKEN}}"
TLS_CERT_PATH="{{TLS_CERT_PATH}}"
TLS_KEY_PATH="{{TLS_KEY_PATH}}"
# cert 父目录由 dirname 派生, 跟 cert 路径绑死
TLS_DIR="$(dirname "$TLS_CERT_PATH")"

if [[ -z "$DOMAIN" ]]; then
    err "useTls=true 但 DOMAIN 为空, 上层应拦在前面; 请检查 nook 后端 reqVO 校验"
    exit 1
fi

mkdir -p "$TLS_DIR"
chmod 700 "$TLS_DIR"

NEED_ISSUE=1
# -checkend 用退出码; -checkhost 两侧退出码都为 0, 必须抓 "does match" 输出
if [[ -f "$TLS_CERT_PATH" && -f "$TLS_KEY_PATH" ]] \
    && openssl x509 -checkend $((7*86400)) -noout -in "$TLS_CERT_PATH" 2>/dev/null \
    && openssl x509 -checkhost "$DOMAIN" -noout -in "$TLS_CERT_PATH" 2>/dev/null \
        | grep -q "does match"; then
    log "✔ 已有 TLS 证书匹配 $DOMAIN 且剩余 > 7 天, 跳过 acme.sh 签发"
    NEED_ISSUE=0
fi

if [[ $NEED_ISSUE -eq 1 ]]; then
    if [[ -z "$CF_API_TOKEN" ]]; then
        err "需要签发 TLS 证书但 cfApiToken 为空 — 填入 Token 或先把现有 cert/key 放到 $TLS_DIR"
        exit 1
    fi

    log "为 $DOMAIN 签发 TLS (acme.sh + Cloudflare DNS-01)..."
    if [[ ! -f "$HOME/.acme.sh/acme.sh" ]]; then
        curl -fsSL https://get.acme.sh | sh -s email="admin@$DOMAIN" >/dev/null
    fi
    "$HOME/.acme.sh/acme.sh" --set-default-ca --server letsencrypt >/dev/null 2>&1 || true

    export CF_Token="$CF_API_TOKEN"
    # --force 兜底 acme 内部缓存与本地 cert 路径不同步; rate-limit 闸门在前面 openssl 检查
    if ! "$HOME/.acme.sh/acme.sh" --issue --dns dns_cf -d "$DOMAIN" --keylength 2048 --force; then
        err "acme.sh 签发失败! 检查 CF Token (Zone:Read + DNS:Edit) + DNS 解析"
        exit 1
    fi
    # reloadcmd 让 acme.sh 自动续期时 (90 天周期) 通知 xray reload 用新证书
    "$HOME/.acme.sh/acme.sh" --install-cert -d "$DOMAIN" \
        --key-file       "$TLS_KEY_PATH" \
        --fullchain-file "$TLS_CERT_PATH" \
        --reloadcmd      "systemctl reload-or-restart xray 2>/dev/null || true"
    log "✔ TLS 证书 → $TLS_CERT_PATH"
fi
