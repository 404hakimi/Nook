# Module 00 — Ubuntu/arch 校验 + apt 装公共工具链 (curl/wget/jq/iproute2).

# nook 后台 SSH 走非交互模式, 非 TTY 分支不带 ANSI 码
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

# Ubuntu 24 默认装了 unattended-upgrades 后台跑安全更新, 装机时跟我们抢 dpkg 锁.
# 调 apt 前先等它释放 (最多 ${1:-300} 秒); 后续模块用到 apt-get 的也调一次.
wait_for_dpkg_lock() {
    local max_wait=${1:-300}
    local waited=0
    while fuser /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock >/dev/null 2>&1; do
        if [[ $waited -ge $max_wait ]]; then
            err "等 dpkg lock 超时 ${max_wait}s (unattended-upgrades 还在跑?)"
            return 1
        fi
        [[ $waited -eq 0 ]] && warn "dpkg 锁被占用 (大概率是 unattended-upgrades), 等待释放..."
        sleep 5
        waited=$((waited + 5))
    done
    [[ $waited -gt 0 ]] && log "✔ dpkg 锁已释放 (等了 ${waited}s)"
    return 0
}

log "=== Module 00: 环境检查 ==="

[[ $EUID -eq 0 ]] || { err "需 root 权限"; exit 1; }

[[ -f /etc/os-release ]] || { err "无法识别系统"; exit 1; }
. /etc/os-release
[[ "$ID" == "ubuntu" && "${VERSION_ID%.*}" -ge 22 ]] \
    || { err "仅支持 Ubuntu 22.04+, 当前: $ID $VERSION_ID"; exit 1; }

ARCH=$(dpkg --print-architecture)
[[ "$ARCH" == "amd64" || "$ARCH" == "arm64" ]] \
    || { err "仅支持 amd64/arm64, 当前: $ARCH"; exit 1; }

log "✔ 系统 OK: Ubuntu $VERSION_ID $ARCH"

log "更新 apt + 装基础工具 (curl/wget/jq/iproute2)..."
export DEBIAN_FRONTEND=noninteractive
wait_for_dpkg_lock
apt-get update -qq
apt-get install -y -qq curl wget unzip ca-certificates iproute2 jq

log "✔ Module 00 完成"
