# Module 40 — UFW 防火墙; 只开 22 + 共享 inbound 端口, gRPC API 走 loopback + SSH 隧道不开公网.

log "=== Module 40: UFW + 防火墙规则 ==="

wait_for_dpkg_lock
apt-get install -y -qq ufw

# reset 避免历史规则污染
ufw --force reset >/dev/null

ufw default deny incoming >/dev/null
ufw default allow outgoing >/dev/null

ufw allow 22/tcp comment "SSH" >/dev/null
ufw allow {{SHARED_INBOUND_PORT}}/tcp comment "xray shared inbound" >/dev/null
# 完整重排: 后台经 44844 call agent 部署/重建; 不放行则启用 UFW 后后台连不到 agent
ufw allow 44844/tcp comment "nook agent control" >/dev/null

ufw --force enable >/dev/null

log "✔ UFW 已启用, 开放端口: 22, {{SHARED_INBOUND_PORT}} (共享 inbound), 44844 (agent control)"
