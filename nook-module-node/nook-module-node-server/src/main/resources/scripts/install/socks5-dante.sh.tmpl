#!/usr/bin/env bash
#
# Nook SOCKS5 落地节点安装脚本 — dante-server + PAM 用户密码认证.
# 渲染时间: {{RENDER_AT}}
#

set -euo pipefail

SOCKS_PORT="{{SOCKS_PORT}}"
SSH_PORT="{{SSH_PORT}}"
SOCKS_USER="{{SOCKS_USER}}"
SOCKS_PASS="{{SOCKS_PASS}}"
LOG_LEVEL="{{LOG_LEVEL}}"
LOG_PATH="{{LOG_PATH}}"
AUTOSTART_ENABLED="{{AUTOSTART_ENABLED}}"
FIREWALL_ENABLED="{{FIREWALL_ENABLED}}"
INSTALL_DIR="{{INSTALL_DIR}}"

# 路径前端 default 给, 默认到 INSTALL_DIR 下方便 SSH 进机器集中探查 (PAM 例外 — OS 强制在 /etc/pam.d/).
DANTE_CONF="{{CONF_PATH}}"
PAM_FILE="{{PAM_FILE}}"
PWDFILE="{{PWD_FILE}}"
SYSTEMD_UNIT="{{SYSTEMD_UNIT}}"

if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

[[ $EUID -eq 0 ]] || { err "需 root"; exit 1; }
[[ -f /etc/os-release ]] || { err "无法识别系统"; exit 1; }
. /etc/os-release
[[ "$ID" == "ubuntu" && "${VERSION_ID%.*}" -ge 22 ]] \
    || { err "仅支持 Ubuntu 22.04+, 当前: $ID $VERSION_ID"; exit 1; }
log "系统 OK: Ubuntu $VERSION_ID"

# 统一 Asia/Shanghai (跟 xray 部署同口径, 跨节点时间戳一致便于排障)
TARGET_TZ="Asia/Shanghai"
CURRENT_TZ=$(timedatectl show -p Timezone --value 2>/dev/null || echo "")
if [[ "$CURRENT_TZ" != "$TARGET_TZ" ]]; then
    if timedatectl set-timezone "$TARGET_TZ" 2>/dev/null; then
        log "时区 $CURRENT_TZ → $TARGET_TZ"
    else
        warn "时区设置失败, 当前: $CURRENT_TZ (不阻塞)"
    fi
else
    log "时区已是 $TARGET_TZ"
fi

log "准备安装目录: $INSTALL_DIR (logs/etc)"
mkdir -p "$INSTALL_DIR/logs" "$INSTALL_DIR/etc"
chmod 755 "$INSTALL_DIR"

export DEBIAN_FRONTEND=noninteractive
log "安装 dante-server + apache2-utils + libpam-pwdfile..."
apt-get update -qq
apt-get install -y -qq dante-server apache2-utils libpam-pwdfile iproute2 curl

# default route 出口 iface; 失败兜底环回防 conf 语法挂掉
EXT_IF=$(awk '$2 == "00000000" {print $1; exit}' /proc/net/route 2>/dev/null || echo "lo")
log "出网网卡: $EXT_IF"

log "配置 PAM (pam_pwdfile -> $PWDFILE)..."
mkdir -p "$(dirname "$PWDFILE")"
cat > "$PAM_FILE" <<PAM
# Generated by nook install-dante-landing
auth     required pam_pwdfile.so pwdfile=$PWDFILE
account  required pam_permit.so
PAM
chmod 644 "$PAM_FILE"

log "写用户凭据: $SOCKS_USER"
htpasswd -bcB "$PWDFILE" "$SOCKS_USER" "$SOCKS_PASS"
chmod 600 "$PWDFILE"

log "写 $DANTE_CONF (port=$SOCKS_PORT log='$LOG_LEVEL')..."
# DANTE_CONF 在 INSTALL_DIR 子目录, 先建目录
mkdir -p "$(dirname "$DANTE_CONF")"
if [[ -f "$DANTE_CONF" ]]; then
    cp "$DANTE_CONF" "${DANTE_CONF}.bak.$(date +%s)"
fi
cat > "$DANTE_CONF" <<DANTECONF
# Generated by nook install-dante-landing
logoutput: $LOG_PATH

internal: 0.0.0.0 port = $SOCKS_PORT
external: $EXT_IF

socksmethod: pam.username
clientmethod: none

user.privileged: root
user.notprivileged: root

client pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: $LOG_LEVEL
}

socks pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    socksmethod: pam.username
    log: $LOG_LEVEL
}

socks block {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: error
}
DANTECONF
chmod 644 "$DANTE_CONF"

# logoutput 不会自己 mkdir
LOG_DIR=$(dirname "$LOG_PATH")
[[ "$LOG_DIR" != "." && "$LOG_DIR" != "/" ]] && mkdir -p "$LOG_DIR"
touch "$LOG_PATH"
chmod 644 "$LOG_PATH"

# Nook 装机 drop-in: 同时做两件事
#   1) 解除 apt 包默认 sandbox: InaccessibleDirectories=/home + ReadOnlyDirectories=/var, 不解除 dante 看不到 /home/socks5/, 也写不进 /var/log/
#   2) 覆盖 ExecStart 让 danted 读自定义 conf 路径 (不再用 apt 默认的 /etc/danted.conf), 用户运维 cd /home/socks5/etc 看真文件
log "写 systemd drop-in (解除 sandbox + 覆盖 ExecStart → $DANTE_CONF)..."
mkdir -p "/etc/systemd/system/${SYSTEMD_UNIT}.service.d"
cat > "/etc/systemd/system/${SYSTEMD_UNIT}.service.d/nook.conf" <<DROPIN
# Nook override: 解除 apt 包 sandbox + 改 conf 路径
[Service]
InaccessibleDirectories=
ReadOnlyDirectories=
ExecStart=
ExecStart=/usr/sbin/danted -f $DANTE_CONF
DROPIN

systemctl stop "${SYSTEMD_UNIT}" >/dev/null 2>&1 || true

log "配置 systemd (autostart=$AUTOSTART_ENABLED unit=${SYSTEMD_UNIT})..."
systemctl daemon-reload
if [[ "$AUTOSTART_ENABLED" == "1" || "$AUTOSTART_ENABLED" == "true" ]]; then
    systemctl enable "${SYSTEMD_UNIT}" >/dev/null 2>&1
else
    systemctl disable "${SYSTEMD_UNIT}" >/dev/null 2>&1
fi
systemctl restart "${SYSTEMD_UNIT}"
sleep 1
if ! systemctl is-active --quiet "${SYSTEMD_UNIT}"; then
    err "${SYSTEMD_UNIT} 启动失败!"
    journalctl -u "${SYSTEMD_UNIT}" -n 30 --no-pager
    exit 1
fi
if ! ss -ltn 2>/dev/null | grep -q ":$SOCKS_PORT "; then
    err "SOCKS5 端口 $SOCKS_PORT 未监听!"
    journalctl -u "${SYSTEMD_UNIT}" -n 30 --no-pager
    exit 1
fi
log "✔ dante SOCKS5 监听 0.0.0.0:$SOCKS_PORT (systemd unit=${SYSTEMD_UNIT})"

if [[ "$FIREWALL_ENABLED" == "1" || "$FIREWALL_ENABLED" == "true" ]]; then
    log "配置 UFW..."
    apt-get install -y -qq ufw
    ufw --force reset >/dev/null
    ufw default deny incoming >/dev/null
    ufw default allow outgoing >/dev/null
    # SSH 端口走入参防止改过端口的远端被 reset 锁外面
    ufw allow "${SSH_PORT}/tcp" comment "SSH" >/dev/null
    ufw allow "${SOCKS_PORT}/tcp" comment "SOCKS5" >/dev/null
    ufw allow "${SOCKS_PORT}/udp" comment "SOCKS5" >/dev/null
    ufw --force enable >/dev/null
    log "UFW: SSH(${SSH_PORT}) + SOCKS5(${SOCKS_PORT}) 已放行"
else
    warn "FIREWALL_ENABLED=0, 跳过 UFW 配置"
fi

log "自检 SOCKS5 拨号..."
PUB=$(curl -s --max-time 10 \
    --socks5 "$SOCKS_USER:$SOCKS_PASS@127.0.0.1:$SOCKS_PORT" \
    https://ipinfo.io/ip 2>/dev/null || echo "TEST_FAILED")

if [[ "$PUB" == "TEST_FAILED" ]]; then
    warn "本地 SOCKS5 自检失败, 但服务已起来; journalctl -u ${SYSTEMD_UNIT} 查原因"
    PUB=$(curl -s4 --max-time 5 ifconfig.me || echo "<your-ip>")
fi

cat > "$INSTALL_DIR/info.txt" <<INFO
# Nook SOCKS5 落地节点 (dante-server)
install_at: $(date '+%Y-%m-%d %H:%M:%S %z')
install_dir: $INSTALL_DIR
socks5_port: $SOCKS_PORT
socks5_user: $SOCKS_USER
listen: 0.0.0.0:$SOCKS_PORT
external_iface: $EXT_IF
log_path: $LOG_PATH (level: $LOG_LEVEL)
danted_conf: $DANTE_CONF
pam_file: $PAM_FILE
pwdfile: $PWDFILE
systemd_unit: $SYSTEMD_UNIT
autostart: $AUTOSTART_ENABLED
firewall: $FIREWALL_ENABLED

# 常用排障命令
systemctl status $SYSTEMD_UNIT
journalctl -u $SYSTEMD_UNIT -n 100 --no-pager
tail -f $LOG_PATH
INFO
chmod 644 "$INSTALL_DIR/info.txt"

# ===== logrotate: size-based + gzip + copytruncate, 0 中断, 适合低配机 =====
if [[ "{{LOG_ROTATE_ENABLED}}" == "1" ]]; then
    if ! command -v logrotate >/dev/null 2>&1; then
        apt-get install -y -qq logrotate
    fi
    cat > /etc/logrotate.d/dante <<EOF
$LOG_PATH {
    size 50M
    rotate 5
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
EOF
    # 立即跑一次校验语法 / 验证路径; 失败仅 warn, cron 后续会修复
    logrotate -f /etc/logrotate.d/dante 2>/dev/null \
      && echo "  ✔ logrotate 已配置 ($LOG_PATH ≥50M 触发滚动, 保留 5 份 gzip 压缩)" \
      || echo "  ⚠ logrotate 配置有问题, 可手动 logrotate -f /etc/logrotate.d/dante 排查"
fi

echo ""
echo -e "${GREEN}━━━━━━━━ 落地节点安装完成 (dante-server) ━━━━━━━━${NC}"
echo "  SOCKS5 地址:  $PUB:$SOCKS_PORT"
echo "  用户/密码:    $SOCKS_USER / ********"
echo "  出网网卡:     $EXT_IF (出网 IP: $PUB)"
echo "  自启:         $AUTOSTART_ENABLED"
echo "  安装目录:     $INSTALL_DIR (info.txt + logs/)"
echo "  日志:         $LOG_PATH (level: $LOG_LEVEL)"
echo ""
