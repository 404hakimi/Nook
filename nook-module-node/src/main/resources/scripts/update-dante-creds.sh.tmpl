#!/usr/bin/env bash
#
# Nook SOCKS5 凭据热更新脚本 (dante-server + PAM).
# 用途: 改 port / user / password / log / firewall 等参数, 不重装包.
#
# 核心优势: PAM pam_pwdfile 每次连接重读密码文件, 改 user/pass 零 downtime;
# 仅当 port / log_level / log_path / external_iface 等需要改 danted.conf 时才 restart 服务.
#
# 渲染时间: {{RENDER_AT}}
#

set -euo pipefail

# 新值 (来自 DB 当前状态)
NEW_SOCKS_PORT="{{SOCKS_PORT}}"
NEW_SOCKS_USER="{{SOCKS_USER}}"
NEW_SOCKS_PASS="{{SOCKS_PASS}}"
NEW_LOG_LEVEL="{{LOG_LEVEL}}"
NEW_LOG_PATH="{{LOG_PATH}}"
NEW_AUTOSTART_ENABLED="{{AUTOSTART_ENABLED}}"
NEW_FIREWALL_ENABLED="{{FIREWALL_ENABLED}}"
NEW_ALLOW_FROM="{{ALLOW_FROM}}"
SSH_PORT="{{SSH_PORT}}"
INSTALL_DIR="{{INSTALL_DIR}}"

DANTE_CONF=/etc/danted.conf
PWDFILE=/etc/danted/sockd.passwd

if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

[[ $EUID -eq 0 ]] || { err "需 root"; exit 1; }
[[ -f "$DANTE_CONF" ]] || { err "dante 未安装 ($DANTE_CONF 不存在), 请先走 install-dante"; exit 1; }
command -v htpasswd >/dev/null || { err "htpasswd 未装, apt install apache2-utils"; exit 1; }

# ===== 1. 改 PAM 密码文件 (零 downtime) =====
# pam_pwdfile 每次连接重读, 改完立即生效, 不动 dante 服务
log "更新用户凭据: $NEW_SOCKS_USER"
if [[ -f "$PWDFILE" ]]; then
    # 删旧 user 再加新 (兼容用户名变更); -D 在文件中不存在该 user 时会非 0 退出, || true 兜底
    while IFS=: read -r u _; do
        [[ -n "$u" && "$u" != "$NEW_SOCKS_USER" ]] && htpasswd -D "$PWDFILE" "$u" >/dev/null 2>&1 || true
    done < "$PWDFILE"
    htpasswd -bB "$PWDFILE" "$NEW_SOCKS_USER" "$NEW_SOCKS_PASS"
else
    htpasswd -bcB "$PWDFILE" "$NEW_SOCKS_USER" "$NEW_SOCKS_PASS"
fi
chmod 600 "$PWDFILE"

# ===== 2. 检测 danted.conf 是否需要改 (port / log_level / log_path) =====
NEED_RESTART=0
CUR_PORT=$(awk '/^internal:/ { for (i=1;i<=NF;i++) if ($i=="=") { print $(i+1); exit } }' "$DANTE_CONF" 2>/dev/null || echo "")
CUR_LOG_PATH=$(awk '/^logoutput:/ { print $2; exit }' "$DANTE_CONF" 2>/dev/null || echo "")

if [[ "$CUR_PORT" != "$NEW_SOCKS_PORT" ]] || [[ "$CUR_LOG_PATH" != "$NEW_LOG_PATH" ]]; then
    NEED_RESTART=1
    log "检测到 port/log 变化 (port: $CUR_PORT -> $NEW_SOCKS_PORT, log: $CUR_LOG_PATH -> $NEW_LOG_PATH), 重写 conf..."
    # 备份
    cp "$DANTE_CONF" "${DANTE_CONF}.bak.$(date +%s)"
    # 探测出网网卡
    EXT_IF=$(awk '$2 == "00000000" {print $1; exit}' /proc/net/route 2>/dev/null || echo "lo")
    cat > "$DANTE_CONF" <<DANTECONF
# Updated by nook update-dante-creds
logoutput: $NEW_LOG_PATH

internal: 0.0.0.0 port = $NEW_SOCKS_PORT
external: $EXT_IF

socksmethod: pam.username
clientmethod: none

user.privileged: root
user.notprivileged: nobody

client pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: $NEW_LOG_LEVEL
}

socks pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    socksmethod: pam.username
    log: $NEW_LOG_LEVEL
}

socks block {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: error
}
DANTECONF
    chmod 644 "$DANTE_CONF"
    # 日志文件准备
    LOG_DIR=$(dirname "$NEW_LOG_PATH")
    [[ "$LOG_DIR" != "." && "$LOG_DIR" != "/" ]] && mkdir -p "$LOG_DIR"
    touch "$NEW_LOG_PATH"; chmod 640 "$NEW_LOG_PATH"
elif ! grep -qF "log: $NEW_LOG_LEVEL" "$DANTE_CONF"; then
    # log_level 改了但 port/path 没变 — sed 替换 log 行 (匹配 "log: <旧值>")
    log "log_level 变化, sed 替换..."
    sed -i -E "s/^([[:space:]]*log:[[:space:]]+).+\$/\\1$NEW_LOG_LEVEL/" "$DANTE_CONF"
    # 注意: socks block 段的 'log: error' 也会被替换, 但只要 NEW_LOG_LEVEL 包含 error 行为还 ok;
    # 若担心可改为更精确匹配, 暂时简化
    NEED_RESTART=1
fi

# ===== 3. systemd autostart 切换 =====
if [[ "$NEW_AUTOSTART_ENABLED" == "1" || "$NEW_AUTOSTART_ENABLED" == "true" ]]; then
    systemctl enable danted >/dev/null 2>&1 || true
else
    systemctl disable danted >/dev/null 2>&1 || true
fi

# ===== 4. UFW 重新配 (规则差异检测代价大, 直接 reset + 重建) =====
if [[ "$NEW_FIREWALL_ENABLED" == "1" || "$NEW_FIREWALL_ENABLED" == "true" ]]; then
    if command -v ufw >/dev/null; then
        log "重写 UFW (allow_from=$NEW_ALLOW_FROM)..."
        ufw --force reset >/dev/null
        ufw default deny incoming >/dev/null
        ufw default allow outgoing >/dev/null
        # SSH 端口走入参 (默认 22), 防止改过端口的远端被 reset 锁外面
        ufw allow "${SSH_PORT}/tcp" comment "SSH" >/dev/null
        ufw allow from "$NEW_ALLOW_FROM" to any port "$NEW_SOCKS_PORT" proto tcp >/dev/null
        ufw allow from "$NEW_ALLOW_FROM" to any port "$NEW_SOCKS_PORT" proto udp >/dev/null
        ufw --force enable >/dev/null
    else
        warn "FIREWALL_ENABLED=1 但 ufw 未装, 跳过"
    fi
else
    warn "FIREWALL_ENABLED=0, 跳过 UFW 配置"
fi

# ===== 5. 仅 conf 改了才 restart, 否则 zero downtime =====
if [[ "$NEED_RESTART" == "1" ]]; then
    log "重启 danted (port / log 变化导致)..."
    systemctl restart danted
    sleep 1
    if ! systemctl is-active --quiet danted; then
        err "danted restart 失败!"
        journalctl -u danted -n 30 --no-pager
        exit 1
    fi
    log "✔ danted 已重启, 监听 :$NEW_SOCKS_PORT"
else
    log "✔ 仅凭据变化, PAM 自动重读, 零 downtime"
fi

# ===== 自检 =====
PUB=$(curl -s --max-time 10 \
    --socks5 "$NEW_SOCKS_USER:$NEW_SOCKS_PASS@127.0.0.1:$NEW_SOCKS_PORT" \
    https://ipinfo.io/ip 2>/dev/null || echo "TEST_FAILED")
if [[ "$PUB" == "TEST_FAILED" ]]; then
    warn "自检失败, 但服务状态 OK; journalctl -u danted 看具体原因"
else
    log "自检通过, 出网 IP: $PUB"
fi

# ===== 刷新 info.txt (运维入口配置随 DB 同步) =====
if [[ -n "$INSTALL_DIR" && -d "$INSTALL_DIR" ]]; then
    cat > "$INSTALL_DIR/info.txt" <<INFO
# Nook SOCKS5 落地节点 (dante-server)
last_sync_at: $(date '+%Y-%m-%d %H:%M:%S %z')
install_dir: $INSTALL_DIR
socks5_port: $NEW_SOCKS_PORT
socks5_user: $NEW_SOCKS_USER
log_path: $NEW_LOG_PATH (level: $NEW_LOG_LEVEL)
danted_conf: $DANTE_CONF
pwdfile: $PWDFILE
autostart: $NEW_AUTOSTART_ENABLED
firewall: $NEW_FIREWALL_ENABLED (allow_from: $NEW_ALLOW_FROM)

# 常用排障命令
systemctl status danted
journalctl -u danted -n 100 --no-pager
tail -f $NEW_LOG_PATH
INFO
    chmod 644 "$INSTALL_DIR/info.txt"
fi
