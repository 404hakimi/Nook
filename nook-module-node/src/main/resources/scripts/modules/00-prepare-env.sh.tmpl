# ===== Module 00: 基础环境检查 + apt 更新 =====
# server: {{SERVER_NAME}} / 渲染时间: {{RENDER_AT}}

# nook 后台 SSH 非交互模式跑, 走非 TTY 分支不带 ANSI 码
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

log "=== Module 00: 环境检查 ==="

[[ $EUID -eq 0 ]] || { err "需 root 权限"; exit 1; }

[[ -f /etc/os-release ]] || { err "无法识别系统"; exit 1; }
. /etc/os-release
[[ "$ID" == "ubuntu" && "${VERSION_ID%.*}" -ge 22 ]] \
    || { err "仅支持 Ubuntu 22.04+, 当前: $ID $VERSION_ID"; exit 1; }

ARCH=$(dpkg --print-architecture)
[[ "$ARCH" == "amd64" || "$ARCH" == "arm64" ]] \
    || { err "仅支持 amd64/arm64, 当前: $ARCH"; exit 1; }

log "✔ 系统 OK: Ubuntu $VERSION_ID $ARCH"

log "更新 apt + 装基础工具 (curl/wget/jq/iproute2)..."
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq curl wget unzip ca-certificates iproute2 jq

log "✔ Module 00 完成"
