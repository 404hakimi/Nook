# Module 47 — Xray 日志轮转 (logrotate); size-based + gzip + copytruncate, 0 中断, 适合低配机.
#
# 行为:
#   access.log: 单文件 ≥ 50M 触发滚, 保留 5 份压缩历史 (实际占盘 < 30MB)
#   error.log:  单文件 ≥ 10M 触发滚, 保留 3 份 (实际占盘 < 5MB)
#   copytruncate: 不需要 xray reload, 持有的 fd 不变, 不丢日志.

log "=== Module 47: 日志轮转 (logrotate) ==="

wait_for_dpkg_lock
# logrotate 在 Ubuntu/Debian 默认已装, 缺失时补一下; cron 每日自动触发 /etc/cron.daily/logrotate
if ! command -v logrotate >/dev/null 2>&1; then
    apt-get install -y -qq logrotate
fi

cat > /etc/logrotate.d/xray <<EOF
{{LOG_DIR}}/access.log {
    size 50M
    rotate 5
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
{{LOG_DIR}}/error.log {
    size 10M
    rotate 3
    compress
    missingok
    notifempty
    copytruncate
}
EOF

# 立即触发一次 (验证配置无语法错); -d 仅 debug, 我们要真跑, 但加 -f 强制即使未达 size 也跑.
# 失败仅 warn 不阻断 install — 日志轮转后续 cron 会修复.
if logrotate -f /etc/logrotate.d/xray 2>/dev/null; then
    log "✔ logrotate 已配置并验证, xray 日志将在 access.log≥50M/error.log≥10M 时自动滚动"
else
    log "⚠ logrotate 配置失败, 检查 ${LOG_DIR} 路径; 后续可手动 logrotate -f /etc/logrotate.d/xray 验证"
fi
