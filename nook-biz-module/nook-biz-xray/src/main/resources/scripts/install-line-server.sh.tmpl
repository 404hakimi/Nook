#!/usr/bin/env bash
#
# Nook 线路服务器一键安装脚本(由 nook 后台渲染下发)
# 服务器: {{SERVER_NAME}}
# 渲染时间: {{RENDER_AT}}
#
# 装的内容:
#   - Xray 内核(官方版本)
#   - nook 标配 xray.json (含 grpc-api / stats / vmess inbound)
#   - {{INSTALL_UFW_BLOCK_LABEL}}
#   - {{INSTALL_BBR_BLOCK_LABEL}}
#

set -euo pipefail

# ===== 渲染参数(由 nook 注入) =====
VMESS_PORT="{{VMESS_PORT}}"
XRAY_API_PORT="{{XRAY_API_PORT}}"
LOG_DIR="{{LOG_DIR}}"
INSTALL_UFW="{{INSTALL_UFW}}"
ENABLE_BBR="{{ENABLE_BBR}}"

XRAY_CONFIG=/usr/local/etc/xray/config.json

# 仅在 TTY 上加颜色; nook 后台用 SSH 非交互模式跑这个脚本, 走非 TTY 分支不带 ANSI 码
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

# ===== 前置检查 =====

[[ $EUID -eq 0 ]] || { err "需 root"; exit 1; }
[[ -f /etc/os-release ]] || { err "无法识别系统"; exit 1; }
. /etc/os-release
[[ "$ID" == "ubuntu" && "${VERSION_ID%.*}" -ge 22 ]] \
    || { err "仅支持 Ubuntu 22.04+, 当前: $ID $VERSION_ID"; exit 1; }
ARCH=$(dpkg --print-architecture)
[[ "$ARCH" == "amd64" || "$ARCH" == "arm64" ]] \
    || { err "仅支持 amd64/arm64, 当前: $ARCH"; exit 1; }
log "系统 OK: Ubuntu $VERSION_ID $ARCH"

# ===== 基础工具 =====
log "更新 apt + 装基础工具..."
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq curl wget unzip ca-certificates iproute2

# ===== 防火墙(可选) =====
if [[ "$INSTALL_UFW" == "true" ]]; then
    log "装 UFW + 配置规则..."
    apt-get install -y -qq ufw
    ufw --force reset >/dev/null
    ufw default deny incoming >/dev/null
    ufw default allow outgoing >/dev/null
    ufw allow 22/tcp comment "SSH" >/dev/null
    ufw allow "$VMESS_PORT/tcp" comment "vmess inbound" >/dev/null
    # gRPC 走 loopback + SSH 隧道, 不开公网
    ufw --force enable >/dev/null
else
    log "跳过 UFW (INSTALL_UFW=false)"
fi

# ===== BBR 内核优化(可选) =====
if [[ "$ENABLE_BBR" == "true" ]]; then
    log "启用 BBR 拥塞控制..."
    cat > /etc/sysctl.d/90-nook-bbr.conf <<'BBR'
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
BBR
    sysctl -p /etc/sysctl.d/90-nook-bbr.conf >/dev/null 2>&1 || true
    if sysctl net.ipv4.tcp_congestion_control 2>/dev/null | grep -q bbr; then
        log "✔ BBR 启用成功"
    else
        warn "BBR 启用失败(内核可能太老), 跳过"
    fi
else
    log "跳过 BBR (ENABLE_BBR=false)"
fi

# ===== 装 Xray =====
if command -v xray >/dev/null 2>&1 && [[ -f /etc/systemd/system/xray.service ]]; then
    XRAY_VER=$(xray version 2>/dev/null | head -1 || echo "?")
    warn "Xray 已装: $XRAY_VER (跳过下载)"
else
    log "下载安装 Xray..."
    bash -c "$(curl -fsSL https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)" @ install
    XRAY_VER=$(xray version | head -1)
    log "Xray: $XRAY_VER"
fi
systemctl stop xray >/dev/null 2>&1 || true

# ===== 写 nook 标配 xray.json =====
mkdir -p "$LOG_DIR" "$(dirname "$XRAY_CONFIG")"
if [[ -f "$XRAY_CONFIG" ]]; then
    BACKUP="${XRAY_CONFIG}.bak.$(date +%s)"
    cp "$XRAY_CONFIG" "$BACKUP"
    log "原配置备份: $BACKUP"
fi

cat > "$XRAY_CONFIG" <<XRAYCONF
{
  "log": {
    "access": "$LOG_DIR/access.log",
    "error": "$LOG_DIR/error.log",
    "loglevel": "warning"
  },
  "api": {
    "tag": "api",
    "services": ["HandlerService", "LoggerService", "StatsService", "RoutingService"]
  },
  "stats": {},
  "policy": {
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    },
    "levels": {
      "0": { "statsUserUplink": true, "statsUserDownlink": true }
    }
  },
  "inbounds": [
    {
      "tag": "api",
      "listen": "127.0.0.1",
      "port": $XRAY_API_PORT,
      "protocol": "dokodemo-door",
      "settings": { "address": "127.0.0.1" }
    },
    {
      "tag": "vmess-in",
      "listen": "0.0.0.0",
      "port": $VMESS_PORT,
      "protocol": "vmess",
      "settings": { "clients": [] },
      "streamSettings": { "network": "tcp" },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    }
  ],
  "outbounds": [
    { "tag": "api",    "protocol": "freedom" },
    { "tag": "direct", "protocol": "freedom" }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      { "type": "field", "inboundTag": ["api"], "outboundTag": "api" }
    ]
  }
}
XRAYCONF

chmod 644 "$XRAY_CONFIG"
chown -R nobody:nogroup "$LOG_DIR" 2>/dev/null || true

log "验证 Xray 配置..."
# Xray CLI 兼容: 新版(2024+)用 'xray run -test -c'; 老版(1.x)用 'xray test -c'.
# 两个都试,任一通过即可
test_xray_config() {
    xray run -test -c "$1" >/dev/null 2>&1 \
        || xray test -c "$1" >/dev/null 2>&1
}
if ! test_xray_config "$XRAY_CONFIG"; then
    err "Xray 配置语法错误!"
    # 把真实错误打出来
    xray run -test -c "$XRAY_CONFIG" 2>&1 || xray test -c "$XRAY_CONFIG" 2>&1 || true
    exit 1
fi

# ===== 启动 =====
log "启动 Xray service..."
systemctl daemon-reload
systemctl enable xray >/dev/null 2>&1
systemctl restart xray
sleep 2

if ! systemctl is-active --quiet xray; then
    err "Xray 启动失败!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi

sleep 1
if ss -ltn 2>/dev/null | grep -q "127.0.0.1:$XRAY_API_PORT "; then
    log "✔ Xray gRPC 在监听 127.0.0.1:$XRAY_API_PORT"
else
    err "Xray gRPC 端口未监听!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi
if ss -ltn 2>/dev/null | grep -q ":$VMESS_PORT "; then
    log "✔ vmess inbound 在监听 0.0.0.0:$VMESS_PORT"
fi

PUBLIC_IP=$(curl -s4 --max-time 5 ifconfig.me 2>/dev/null || echo "<your-ip>")

echo ""
echo "${GREEN}━━━━━━━━ 安装完成 ━━━━━━━━${NC}"
echo "  服务器:    $PUBLIC_IP"
echo "  Xray 版本: $XRAY_VER"
echo "  vmess:     0.0.0.0:$VMESS_PORT"
echo "  gRPC API:  127.0.0.1:$XRAY_API_PORT"
echo ""
echo "返回 nook 后台,点 '测速' 验证 gRPC 通信."
