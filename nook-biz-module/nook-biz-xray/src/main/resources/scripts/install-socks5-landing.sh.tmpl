#!/usr/bin/env bash
#
# Nook SOCKS5 落地节点安装脚本 — 基于 Xray 内核 (与中转节点共享同一二进制 / systemd unit / 部署流程,
# 不再依赖 3proxy 等第三方包).
# 渲染时间: {{RENDER_AT}}
#
# 落地节点的 xray.json 仅含:
#   - inbound: socks 协议, 监听 SOCKS_PORT, password 认证 (SOCKS_USER/SOCKS_PASS)
#   - outbound: freedom (直连出网, 用户最终对外的 IP 即本机公网 IP)
#

set -euo pipefail

SOCKS_PORT="{{SOCKS_PORT}}"
SOCKS_USER="{{SOCKS_USER}}"
SOCKS_PASS="{{SOCKS_PASS}}"
ALLOW_FROM="{{ALLOW_FROM}}"
INSTALL_UFW="{{INSTALL_UFW}}"

XRAY_CONFIG=/usr/local/etc/xray/config.json
LOG_DIR=/var/log/xray

# nook 后台调用走非 TTY 分支, 不带 ANSI 码
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; RED=''; NC=''
fi
log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

# ===== 前置 =====
[[ $EUID -eq 0 ]] || { err "需 root"; exit 1; }
[[ -f /etc/os-release ]] || { err "无法识别系统"; exit 1; }
. /etc/os-release
[[ "$ID" == "ubuntu" && "${VERSION_ID%.*}" -ge 22 ]] \
    || { err "仅支持 Ubuntu 22.04+, 当前: $ID $VERSION_ID"; exit 1; }
log "系统 OK: Ubuntu $VERSION_ID"

export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq curl ca-certificates iproute2

# ===== 装 Xray (与中转节点共享官方安装链) =====
if command -v xray >/dev/null 2>&1 && [[ -f /etc/systemd/system/xray.service ]]; then
    log "Xray 已装: $(xray version 2>/dev/null | head -1) (跳过下载)"
else
    log "下载安装 Xray..."
    bash -c "$(curl -fsSL https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)" @ install
    log "Xray: $(xray version | head -1)"
fi
systemctl stop xray >/dev/null 2>&1 || true

# ===== 专属 xray 用户 + systemd drop-in (与 install-line-server 一致) =====
if ! id xray >/dev/null 2>&1; then
    log "创建专属 xray 系统用户..."
    useradd -r -M -s /usr/sbin/nologin -c "Xray service user" xray
fi
mkdir -p /etc/systemd/system/xray.service.d "$LOG_DIR" "$(dirname "$XRAY_CONFIG")"
cat > /etc/systemd/system/xray.service.d/user.conf <<'OVERRIDE'
[Service]
User=xray
Group=xray
OVERRIDE

# ===== 写 SOCKS5 落地节点 xray.json =====
if [[ -f "$XRAY_CONFIG" ]]; then
    BACKUP="${XRAY_CONFIG}.bak.$(date +%s)"
    cp "$XRAY_CONFIG" "$BACKUP"
    log "原配置备份: $BACKUP"
fi

cat > "$XRAY_CONFIG" <<XRAYCONF
{
  "log": {
    "access": "$LOG_DIR/access.log",
    "error": "$LOG_DIR/error.log",
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": $SOCKS_PORT,
      "protocol": "socks",
      "settings": {
        "auth": "password",
        "accounts": [
          { "user": "$SOCKS_USER", "pass": "$SOCKS_PASS" }
        ],
        "udp": true
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    }
  ],
  "outbounds": [
    { "tag": "direct", "protocol": "freedom" }
  ]
}
XRAYCONF

chown -R xray:xray "$LOG_DIR" 2>/dev/null || true
chown root:xray "$XRAY_CONFIG" 2>/dev/null || true
chmod 640 "$XRAY_CONFIG" 2>/dev/null || true

log "验证 Xray 配置..."
if ! (xray run -test -c "$XRAY_CONFIG" >/dev/null 2>&1 || xray test -c "$XRAY_CONFIG" >/dev/null 2>&1); then
    err "Xray 配置语法错误!"
    xray run -test -c "$XRAY_CONFIG" 2>&1 || xray test -c "$XRAY_CONFIG" 2>&1 || true
    exit 1
fi

# ===== 启动 =====
log "启动 Xray..."
systemctl daemon-reload
systemctl enable xray >/dev/null 2>&1
systemctl restart xray
sleep 2
if ! systemctl is-active --quiet xray; then
    err "Xray 启动失败!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi
if ! ss -ltn 2>/dev/null | grep -q ":$SOCKS_PORT "; then
    err "SOCKS5 端口 $SOCKS_PORT 未监听!"
    journalctl -u xray -n 30 --no-pager
    exit 1
fi
log "✔ Xray SOCKS5 监听 0.0.0.0:$SOCKS_PORT"

# ===== UFW (可选) =====
if [[ "$INSTALL_UFW" == "true" ]]; then
    apt-get install -y -qq ufw
    ufw --force reset >/dev/null
    ufw default deny incoming >/dev/null
    ufw default allow outgoing >/dev/null
    ufw allow 22/tcp comment "SSH" >/dev/null
    ufw allow from "$ALLOW_FROM" to any port "$SOCKS_PORT" proto tcp >/dev/null
    ufw allow from "$ALLOW_FROM" to any port "$SOCKS_PORT" proto udp >/dev/null
    ufw --force enable >/dev/null
    log "UFW: SOCKS5 仅允许来源 $ALLOW_FROM"
fi

# ===== 自检 =====
log "自检..."
PUB=$(curl -s --max-time 10 \
    --socks5 "$SOCKS_USER:$SOCKS_PASS@127.0.0.1:$SOCKS_PORT" \
    https://ipinfo.io/ip 2>/dev/null || echo "TEST_FAILED")

if [[ "$PUB" == "TEST_FAILED" ]]; then
    warn "本地 SOCKS5 自检失败, 但服务已起来; 检查 journalctl -u xray"
    PUB=$(curl -s4 --max-time 5 ifconfig.me || echo "<your-ip>")
fi

echo ""
echo "${GREEN}━━━━━━━━ 落地节点安装完成 ━━━━━━━━${NC}"
echo "  SOCKS5 地址:  $PUB:$SOCKS_PORT"
echo "  用户/密码:    $SOCKS_USER / $SOCKS_PASS"
echo "  允许来源:     $ALLOW_FROM"
echo "  出网 IP:      $PUB"
echo ""
